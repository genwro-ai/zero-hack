#!/bin/bash
#SBATCH --job-name=zero-hack-evalsets
#SBATCH --array=0-3
#SBATCH --account=euhpc_d30_031
#SBATCH --partition=boost_usr_prod
#SBATCH --reservation=s_tra_ncc # Reservation for the hackathon
#SBATCH --nodes=1
#SBATCH --ntasks-per-node=1
#SBATCH --mem=32GB
#SBATCH --cpus-per-task=4
#SBATCH --time=0:30:00
#SBATCH --output=outputs/slurm/%x_%A_%a.out
#SBATCH --error=outputs/slurm/%x_%A_%a.err

set -euo pipefail

# Slurm array job for creating local eval sets under data/eval from the
# provided Industrial *_variants.csv files.
#
# For each generated dataset size, this creates the three holdout combinations:
#   data/eval/valid_s005k/holdout_mosfet/id
#   data/eval/valid_s005k/holdout_mosfet/ood
#
# Each holdout directory uses the corresponding two families as train families
# in metadata. The id view evaluates Industrial variants from those two
# families; the ood view evaluates Industrial variants from the holdout family.
# Task 3 anomaly rows are generated by corrupting Industrial variant sequences
# with our rule-based anomaly generator.
# The calibration view is always written for threshold tuning with 650 healthy
# and 350 unhealthy samples from the train families.
#
# Submit with:
#   sbatch slurm/make_eval_sets.sbatch
#
# Optional environment overrides:
#   EVAL_ROOT=data/eval
#   HOLDOUT_FAMILIES="mosfet igbt ic"
#   EVAL_SEED=1729
#   UV_CACHE_DIR=$SCRATCH/.cache/uv
#   UV_INSTALL_DIR=$SCRATCH/.local/bin
#   LEONARDO_LOAD_MODULES=0

if [[ -n "${SCRATCH:-}" ]]; then
  export UV_CACHE_DIR="${UV_CACHE_DIR:-$SCRATCH/.cache/uv}"
fi

if [[ "${LEONARDO_LOAD_MODULES:-1}" == "1" ]] && command -v module >/dev/null 2>&1; then
  module load python/3.11.7 || true
  module load profile/deeplrn || true
fi

cd "${SLURM_SUBMIT_DIR:-$(pwd)}"

source slurm/setup_uv.sh

DATASETS=(
  valid_s005k
  valid_s010k
  valid_s020k
  valid_s100k
)

TASK_ID="${SLURM_ARRAY_TASK_ID:-0}"
DATASET="${DATASETS[$TASK_ID]}"
EVAL_ROOT="${EVAL_ROOT:-data/eval}"
HOLDOUT_FAMILIES="${HOLDOUT_FAMILIES:-mosfet igbt ic}"
EVAL_SEED="${EVAL_SEED:-1729}"
RUNNER="${RUNNER:-srun}"

mkdir -p outputs/slurm "$EVAL_ROOT"

printf "task_id=%s dataset=%s eval_root=%s holdouts=%s\n" \
  "$TASK_ID" "$DATASET" "$EVAL_ROOT" "$HOLDOUT_FAMILIES"

time "$RUNNER" uv run python scripts/make_all_eval_sets.py \
  --datasets "$DATASET" \
  --out-root "$EVAL_ROOT" \
  --holdout-families $HOLDOUT_FAMILIES \
  --seed "$EVAL_SEED"

find "$EVAL_ROOT/$DATASET" -maxdepth 2 -type f -name "*.csv" -exec ls -lh {} +
